{
    "manifest_version": 3,
    "name": "MemoSphere AI Extension",
    "version": "1.0.0",
    "description": "AI-powered meeting assistant with encryption, voice input, and automatic documentation for MemoSphere.",
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "notifications",
        "clipboardWrite",
        "webRequest",
        "alarms"
    ],
    "host_permissions": [
        "https://meet.google.com/*",
        "https://*.zoom.us/*",
        "https://teams.microsoft.com/*",
        "http://localhost/*",
        "https://*.memosphere.io/*",
        "https://*.memosphere.app/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_title": "MemoSphere AI"
    },
    "content_scripts": [{
        "matches": [
            "https://meet.google.com/*",
            "https://*.zoom.us/*",
            "https://teams.microsoft.com/*",
            "http://localhost/*",
            "https://*.memosphere.io/*",
            "https://*.memosphere.app/*"
        ],
        "js": [
            "utils/voice.js",
            "utils/openrouter.js",
            "utils/meeting.js",
            "utils/search.js",
            "content_script.js"
        ],
        "css": [
            "overlay/overlay.css"
        ],
        "run_at": "document_end"
    }],
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Ctrl+Space",
                "mac": "Command+Space"
            },
            "description": "Toggle AI Overlay"
        },
        "global_search": {
            "suggested_key": {
                "default": "Ctrl+Shift+F",
                "mac": "Command+Shift+F"
            },
            "description": "Open Global Search"
        }
    },
    "web_accessible_resources": [{
        "resources": [
            "overlay/*.html",
            "overlay/*.css",
            "overlay/*.js",
            "utils/*.js",
            "icons/*"
        ],
        "matches": ["<all_urls>"]
    }],
    "icons": {
        "16": "icons/icon16.svg",
        "48": "icons/icon48.svg",
        "128": "icons/icon128.svg"
    }
}