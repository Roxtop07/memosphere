# Environment Configuration
# Copy this to .env and fill in your values

# Security
SECRET_KEY=change-this-to-a-secure-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/memosphere
# For development, you can use SQLite:
# DATABASE_URL=sqlite:///./memo_db.sqlite3

# AI Services
OPENAI_API_KEY=sk-your-openai-key-here
OLLAMA_BASE_URL=http://localhost:11434

# HuggingFace (for pyannote.audio and other models)
HUGGINGFACE_TOKEN=hf_your_token_here

# Redis (for caching and Celery)
REDIS_URL=redis://localhost:6379/0

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,chrome-extension://your-extension-id

# Email (optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Monitoring (optional)
SENTRY_DSN=https://your-sentry-dsn

# Storage (optional - for cloud storage)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_S3_BUCKET=memosphere-audio-files
AWS_REGION=us-east-1

# API Keys for external services (optional)
DEEPGRAM_API_KEY=your-deepgram-key
ASSEMBLY_AI_KEY=your-assembly-ai-key

# Model Configuration
DEFAULT_WHISPER_MODEL=base
DEFAULT_TTS_MODEL=xtts_v2
ENABLE_GPU=true
MAX_AUDIO_LENGTH=600  # seconds

# Feature Flags
ENABLE_VOICE_CLONING=true
ENABLE_DIARIZATION=true
ENABLE_EMOTION_DETECTION=true
ENABLE_SPEECH_ENHANCEMENT=true
