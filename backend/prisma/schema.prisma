// Prisma Schema for Sistec Backend - SQLite with Full Features
// Multi-tenancy with RBAC and comprehensive features

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== ORGANIZATIONS ====================

model Organization {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  orgCode     String    @unique
  description String?
  logo        String?
  website     String?
  industry    String?
  size        String?
  settings    String?   // JSON string
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users           User[]
  meetings        Meeting[]
  events          Event[]
  policies        Policy[]
  departments     Department[]
  auditLogs       AuditLog[]
  notifications   Notification[]

  @@map("organizations")
}

// ==================== USERS ====================

model User {
  id                String    @id @default(uuid())
  orgId             String
  email             String
  password          String
  firstName         String
  lastName          String
  phoneNumber       String?
  avatar            String?
  role              String    @default("MEMBER") // ADMIN, ORGANIZER, MEMBER, GUEST
  departmentId      String?
  isActive          Boolean   @default(true)
  isEmailVerified   Boolean   @default(false)
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String?
  lastLoginAt       DateTime?
  lastLoginIp       String?
  loginAttempts     Int       @default(0)
  lockedUntil       DateTime?
  preferences       String?   // JSON string
  timezone          String    @default("UTC")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sessions          Session[]
  refreshTokens     RefreshToken[]
  createdMeetings   Meeting[]    @relation("MeetingCreator")
  meetingAttendees  MeetingAttendee[]
  createdEvents     Event[]      @relation("EventCreator")
  eventAttendees    EventAttendee[]
  createdPolicies   Policy[]     @relation("PolicyCreator")
  notifications     Notification[]
  auditLogs         AuditLog[]
  comments          Comment[]
  actions           Action[]
  uploadedFiles     FileUpload[]
  webhooks          Webhook[]

  @@unique([orgId, email])
  @@map("users")
}

// ==================== DEPARTMENTS ====================

model Department {
  id          String    @id @default(uuid())
  orgId       String
  name        String
  description String?
  parentId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  meetings     Meeting[]
  events       Event[]
  policies     Policy[]

  @@map("departments")
}

// ==================== AUTH ====================

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ==================== MEETINGS ====================

model Meeting {
  id              String    @id @default(uuid())
  orgId           String
  title           String
  description     String?
  agenda          String?
  minutes         String?
  summary         String?
  transcript      String?
  keyPoints       String?   // JSON string
  actionItems     String?   // JSON string
  decisions       String?   // JSON string
  type            String    @default("REGULAR")
  status          String    @default("SCHEDULED")
  startTime       DateTime
  endTime         DateTime
  actualStartTime DateTime?
  actualEndTime   DateTime?
  timezone        String    @default("UTC")
  location        String?
  meetingUrl      String?
  recordingUrl    String?
  isRecurring     Boolean   @default(false)
  recurrenceRule  String?
  isPrivate       Boolean   @default(false)
  tags            String?   // JSON array string
  metadata        String?   // JSON string
  createdById     String
  departmentId    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy    User          @relation("MeetingCreator", fields: [createdById], references: [id])
  department   Department?   @relation(fields: [departmentId], references: [id])
  attendees    MeetingAttendee[]
  actions      Action[]
  comments     Comment[]

  @@map("meetings")
}

model MeetingAttendee {
  id         String   @id @default(uuid())
  meetingId  String
  userId     String
  role       String   @default("PARTICIPANT")
  status     String   @default("PENDING")
  responseAt DateTime?
  checkInAt  DateTime?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@map("meeting_attendees")
}

model Action {
  id          String    @id @default(uuid())
  orgId       String
  meetingId   String
  userId      String
  text        String
  dueDate     DateTime?
  status      String    @default("PENDING")
  priority    String    @default("MEDIUM")
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@map("actions")
}

// ==================== EVENTS ====================

model Event {
  id                   String    @id @default(uuid())
  orgId                String
  title                String
  description          String?
  type                 String    @default("GENERAL")
  status               String    @default("DRAFT")
  startDate            DateTime
  endDate              DateTime
  timezone             String    @default("UTC")
  location             String?
  venue                String?
  address              String?
  isVirtual            Boolean   @default(false)
  virtualUrl           String?
  capacity             Int?
  currentAttendees     Int       @default(0)
  requiresRegistration Boolean   @default(true)
  registrationDeadline DateTime?
  isPublic             Boolean   @default(false)
  coverImage           String?
  agenda               String?   // JSON string
  speakers             String?   // JSON string
  tags                 String?   // JSON array string
  metadata             String?   // JSON string
  createdById          String
  departmentId         String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  organization Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy    User           @relation("EventCreator", fields: [createdById], references: [id])
  department   Department?    @relation(fields: [departmentId], references: [id])
  attendees    EventAttendee[]

  @@map("events")
}

model EventAttendee {
  id           String    @id @default(uuid())
  eventId      String
  userId       String
  status       String    @default("REGISTERED")
  registeredAt DateTime  @default(now())
  checkedInAt  DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("event_attendees")
}

// ==================== POLICIES ====================

model Policy {
  id               String    @id @default(uuid())
  orgId            String
  title            String
  description      String?
  content          String
  type             String    @default("GENERAL")
  category         String?
  status           String    @default("DRAFT")
  version          Int       @default(1)
  effectiveDate    DateTime?
  effectiveEndDate DateTime?
  expiryDate       DateTime?
  isPublic         Boolean   @default(false)
  tags             String?   // JSON array string
  metadata         String?   // JSON string
  createdById      String
  departmentId     String?
  approvedById     String?
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("PolicyCreator", fields: [createdById], references: [id])
  department   Department?  @relation(fields: [departmentId], references: [id])

  @@map("policies")
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id        String   @id @default(uuid())
  orgId     String
  userId    String
  type      String
  title     String
  message   String
  data      String?  // JSON string
  isRead    Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ==================== COMMENTS ====================

model Comment {
  id        String   @id @default(uuid())
  orgId     String
  meetingId String?
  userId    String
  entityType String  // meeting, event, policy
  entityId  String
  content   String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  meeting Meeting? @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("comments")
}

// ==================== AUDIT LOGS ====================

model AuditLog {
  id         String   @id @default(uuid())
  orgId      String
  userId     String?
  action     String
  entityType String
  entityId   String?
  oldValue   String?  // JSON string
  newValue   String?  // JSON string
  ipAddress  String?
  userAgent  String?
  metadata   String?  // JSON string
  createdAt  DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ==================== FILE UPLOADS ====================

model FileUpload {
  id             String   @id @default(uuid())
  orgId          String
  uploadedById   String
  filename       String
  storedFilename String
  mimeType       String
  size           Int
  path           String
  entityType     String?
  entityId       String?
  isPublic       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  uploadedBy User @relation(fields: [uploadedById], references: [id])

  @@map("file_uploads")
}

// ==================== API KEYS ====================

model ApiKey {
  id          String    @id @default(uuid())
  orgId       String
  userId      String
  name        String
  key         String    @unique
  permissions String?   // JSON array string
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("api_keys")
}

// ==================== WEBHOOKS ====================

model Webhook {
  id              String    @id @default(uuid())
  orgId           String
  name            String
  description     String?
  url             String
  secret          String
  events          String    // JSON array of event types
  isActive        Boolean   @default(true)
  lastTriggeredAt DateTime?
  failureCount    Int       @default(0)
  createdById     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  createdBy User @relation(fields: [createdById], references: [id])

  @@map("webhooks")
}
