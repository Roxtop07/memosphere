{
    "name": "memosphere-backend",
    "version": "1.0.0",
    "description": "Complete backend for MemoSphere - Meetings, Events, and Policy Management",
    "main": "dist/server.js",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "setup": "docker-compose up -d && sleep 5 && npm run db:generate && npm run db:migrate && npm run db:rls",
        "db:generate": "prisma generate",
        "db:push": "prisma db push",
        "db:migrate": "prisma migrate dev",
        "db:rls": "docker exec -i sistec-postgres psql -U sistec -d sistec_db < prisma/rls-setup.sql",
        "db:studio": "prisma studio",
        "db:seed": "tsx prisma/seed.ts",
        "test": "jest",
        "test:watch": "jest --watch",
        "lint": "eslint src --ext .ts",
        "format": "prettier --write \"src/**/*.ts\""
    },
    "keywords": [
        "meetings",
        "events",
        "policies",
        "ai",
        "transcription",
        "collaboration"
    ],
    "author": "MemoSphere Team",
    "license": "MIT",
    "dependencies": {
        "@google-cloud/storage": "^7.7.0",
        "@prisma/client": "^5.22.0",
        "@types/bull": "^3.15.9",
        "axios": "^1.6.2",
        "bcryptjs": "^2.4.3",
        "bull": "^4.16.5",
        "compression": "^1.7.4",
        "cors": "^2.8.5",
        "crypto-js": "^4.2.0",
        "date-fns": "^3.0.0",
        "dotenv": "^16.3.1",
        "express": "^4.21.2",
        "express-rate-limit": "^7.1.5",
        "express-validator": "^7.0.1",
        "ffmpeg-static": "^5.2.0",
        "helmet": "^7.1.0",
        "ical-generator": "^6.0.1",
        "ioredis": "^5.8.2",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "natural": "^6.10.3",
        "nodemailer": "^6.10.1",
        "pdf-lib": "^1.17.1",
        "pdfkit": "^0.15.0",
        "qrcode": "^1.5.3",
        "sharp": "^0.33.1",
        "socket.io": "^4.6.0",
        "tesseract.js": "^5.0.4",
        "uuid": "^9.0.1",
        "winston": "^3.18.3",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/compression": "^1.7.5",
        "@types/cors": "^2.8.17",
        "@types/crypto-js": "^4.2.1",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.11",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "^1.9.9",
        "@types/multer": "^1.4.11",
        "@types/node": "^20.10.5",
        "@types/nodemailer": "^6.4.21",
        "@types/pdfkit": "^0.13.4",
        "@types/qrcode": "^1.5.5",
        "@types/socket.io": "^3.0.1",
        "@types/uuid": "^9.0.7",
        "@typescript-eslint/eslint-plugin": "^6.15.0",
        "@typescript-eslint/parser": "^6.15.0",
        "eslint": "^8.56.0",
        "jest": "^29.7.0",
        "prettier": "^3.1.1",
        "prisma": "^5.22.0",
        "ts-jest": "^29.1.1",
        "tsx": "^4.20.6",
        "typescript": "^5.9.3"
    },
    "engines": {
        "node": ">=18.0.0",
        "pnpm": ">=8.0.0"
    }
}
